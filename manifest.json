{
  "manifest_version": 3,
  "name": "Steam Guides Overloaded",
  "version": "0.2.0",
  "description": "Enhanced navigation, real-time validation, and achievement workflow for Steam guide authors.",
  "permissions": ["activeTab", "storage", "downloads"],
  "host_permissions": ["*://steamcommunity.com/*", "*://store.steampowered.com/*"],
  "background": { "service_worker": "src/background/service-worker.js" },
  "action": { "default_popup": "src/core/popup/popup.html" },
  "content_scripts": [{
    "matches": [
      "*://store.steampowered.com/app/*",
      "*://steamcommunity.com/*/guides/*",
      "*://steamcommunity.com/sharedfiles/editguide*",
      "*://steamcommunity.com/sharedfiles/manageguide*",
      "*://steamcommunity.com/sharedfiles/editguidesubsection*"
    ],
    "js": [
      "src/feature/navigation/store-button.js",
      "src/feature/editor/template-system.js",
      "src/feature/guide/editguide-helpers.js",
      "src/feature/guide/manageguide-sections.js",
      "src/feature/guide/game-badge.js",
      "src/feature/guide/guides-panel.js",
      "src/feature/achievements/achievement-panel.js",
      "src/feature/guide/section-cache.js",
      "src/feature/guide/cascade-panel.js",
      "src/feature/guide/staging-buffer-panel.js",
      "src/feature/guide/editguidesubsection-editor.js",
      "src/content.js"
    ],
    "css": ["src/content.css"],
    "run_at": "document_idle"
  }]
}